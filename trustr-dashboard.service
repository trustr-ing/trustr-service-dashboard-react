[Unit]
Description=Trustr Service Dashboard
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/trustr-service-dashboard
Environment=NODE_ENV=production
EnvironmentFile=/opt/trustr-service-dashboard/.env.production
ExecStart=/usr/bin/npm start
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
